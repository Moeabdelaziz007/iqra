.env
.env.local
.env.*
!.env.example

# Dependencies
node_modules/
dist/
.next/

# OS
.DS_Store
*.log
*.tmp
npm-debug.log*

# ── IQRA Sovereign Data — لا يُرفع أبداً ──────────────────────────
# كل محتوى .iqra/ بيانات محلية سيادية، باستثناء محرك النمو (Growth Engine)
.iqra/*
!.iqra/README.md
!.iqra/cycle.txt
!.iqra/scripts/
!.iqra/hooks/
!.iqra/intelligence/
!.iqra/social/
!.iqra/economics/
!.iqra/innovation/
!.iqra/performance/
# لكن النسخ الاحتياطية والنبضات تبقى محلية
.iqra/memory/
.iqra/pulses.jsonl
.iqra_loop_state

# Build artifacts
tsconfig.tsbuildinfo
*.tsbuildinfo
raw_api_payload*.json
*.bak
*.backup

# TypeScript compiler debug snapshots — created ad hoc, never useful in git
ts_errors.txt
tsc_output.txt

# Scratch and debug scripts at the repo root. Real source lives under src/.
/scratch/
/scratch_*.ts
/debug_*.ts
/docs-out/

# Go engine binaries are produced by `npm run engine:build` under /bin/.
# The source under src/services/go-engine/ stays in git; the binary does not.
/bin/iqra-engine
/bin/iqra-engine.exe

# Repomix output — ضخم جداً ولا فائدة منه في git
repomix*.txt
repomix*.json

# Kiro local planning & mapping — خطط محلية
.kiro/mapping/
.kiro/planning/

# Obsidian local settings
.obsidian/

# Knowledge nodes — ملفات محلية متولدة
knowledge/node-*.md
knowledge/simulated/

# Local benchmark & data results
iqra-core/benchmark_results.json
iqra-core/data/reward_ledger.jsonl
iqra-core/data/*.jsonl

# Archive folder — local history and logs
archive/

# MCP local config (may contain tokens)
.ag/mcp.json
mcp.json

# Git temp files
.git_commit_msg.tmp
trust_fallback.log

# Cache and local IDE settings
node-compile-cache/
tsx-*/
.vscode/
.tsx/
deploy.sh
wrangler.toml

# Go build artifacts — compiled binaries must NOT be committed.
# Both used to live next to the source at 9MB each, doubling repo size on every
# rebuild. CI now builds them on-demand.
/src/services/go-engine/go-engine
/src/services/go-engine/iqra-engine
/src/services/go-engine/engine
/src/services/go-engine/*.exe
/src/services/go-engine/*.test
*.exe
