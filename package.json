{
  "name": "iqra",
  "version": "0.3.69",
  "description": "IQRA - Self-evolving AI identity core rooted in القرآن الكريم والسنة النبوية",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest --run",
    "test:e2e": "vitest run tests/e2e/iqra-system-simple.test.ts",
    "test:simple": "vitest run tests/e2e/iqra-system-simple.test.ts",
    "test:watch": "vitest",
    "iqra": "npx tsx src/scripts_v2/interact.ts",
    "iqra:deep": "npx tsx src/scripts_v2/interact.ts --mode deep",
    "iqra:quran": "npx tsx src/scripts_v2/interact.ts --mode quran",
    "iqra:en": "npx tsx src/scripts_v2/interact.ts --lang en",
    "run-mission": "npx tsx src/scripts_v2/run_mission.ts",
    "run-mission:test": "npx tsx src/scripts_v2/run_mission.ts missions/topological-curiosity.yaml",
    "integrity:check": "node --import tsx src/scripts_v2/integrity_check.ts",
    "engine:start": "cd src/services/go-engine && go run ./cmd/server",
    "engine:build": "mkdir -p bin && cd src/services/go-engine && go build -o ../../../bin/iqra-engine ./cmd/server",
    "iqra:simulate": "node --import tsx src/scripts_v2/self_play_simulation.ts",
    "evolution:soul": "npx tsx scripts/evolution_soul.ts",
    "iqra:grow": "npx tsx .iqra/scripts/run-cycle.ts",
    "iqra:backup": "npx tsx .iqra/scripts/backup-smart.ts",
    "iqra:index": "npx tsx .iqra/scripts/auto-indexer.ts",
    "iqra:guard:names": "npx tsx .iqra/hooks/name-validator.ts",
    "iqra:guard:secrets": "npx tsx .iqra/hooks/secret-guard.ts",
    "iqra:guard:size": "npx tsx .iqra/hooks/size-guard.ts",
    "iqra:guard:all": "npx tsx .iqra/hooks/name-validator.ts --all && npx tsx .iqra/hooks/secret-guard.ts --all && npx tsx .iqra/hooks/size-guard.ts --all"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Moeabdelaziz007/iqra.git"
  },
  "keywords": [
    "ai",
    "quran",
    "islamic-ai",
    "sovereign-ai",
    "rag"
  ],
  "author": "Moe Abdelaziz",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Moeabdelaziz007/iqra/issues"
  },
  "homepage": "https://github.com/Moeabdelaziz007/iqra#readme",
  "imports": {
    "#manifest/*": "./src/lib/iqra/00-manifest/*",
    "#core/*": "./src/lib/iqra/01-core/*",
    "#iqra-core/*": "./src/lib/iqra/01-core/*",
    "#errors/*": "./src/lib/iqra/01-core/*",
    "#orchestrator/*": "./src/lib/iqra/01-core/*",
    "#workers/*": "./src/lib/iqra/02-workers/*",
    "#memory/*": "./src/lib/iqra/03-memory/*",
    "#quran/*": "./src/lib/iqra/04-quran/*",
    "#rewards/*": "./src/lib/iqra/05-rewards/*",
    "#security/*": "./src/lib/iqra/06-security/*",
    "#llm/*": "./src/lib/iqra/07-llm/*",
    "#skills/*": "./src/lib/iqra/08-skills/*",
    "#cognitive/*": "./src/lib/iqra/08-cognitive/*",
    "#evolution/*": "./src/lib/iqra/09-evolution/*",
    "#topology/*": "./src/lib/iqra/10-topology/*",
    "#trading/*": "./src/lib/iqra/11-trading/*",
    "#infra/*": "./src/lib/iqra/12-infrastructure/*",
    "#utils/*": "./src/lib/iqra/13-utils/*",
    "#aix/*": "./src/lib/iqra/14-aix/*",
    "#agents/*": "./src/lib/iqra/01-core/agents/*",
    "#runtime/*": "./src/lib/iqra/12-infrastructure/*",
    "#tests/*": "./src/tests/*",
    "#sovereign_orchestrator": "./src/lib/iqra/01-core/sovereign_orchestrator"
  },
  "dependencies": {
    "@google/adk": "^1.1.0",
    "@google/adk-devtools": "^1.1.0",
    "@google/generative-ai": "^0.21.0",
    "@lancedb/lancedb": "^0.27.2",
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^1.8.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@supabase/supabase-js": "^2.45.6",
    "@upstash/redis": "^1.34.3",
    "groq-sdk": "^0.8.0",
    "imapflow": "^1.0.0",
    "lancedb": "^0.0.1",
    "mailparser": "^3.0.0",
    "next": "^15.0.0",
    "openai": "^4.73.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^2.0.0",
    "sqlite-vec": "^0.1.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.41",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "better-sqlite3": "^12.9.0",
    "boxen": "^8.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^8",
    "eslint-config-next": "^15.0.0",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "ora": "^8.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.9"
  }
}
