{
  "name": "iqra",
  "version": "1.0.0",
  "description": "IQRA - Self-evolving AI identity core rooted in القرآن الكريم والسنة النبوية",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest --run",
    "test:e2e": "vitest --run --reporter=verbose",
    "test:watch": "vitest",
    "iqra": "npx tsx scripts/interact.ts",
    "iqra:deep": "npx tsx scripts/interact.ts --mode deep",
    "iqra:quran": "npx tsx scripts/interact.ts --mode quran",
    "iqra:en": "npx tsx scripts/interact.ts --lang en",
    "engine:start": "cd services/go-engine && go run .",
    "engine:build": "cd services/go-engine && go build -o ../../bin/iqra-engine main.go"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Moeabdelaziz007/iqra.git"
  },
  "keywords": [
    "ai",
    "quran",
    "islamic-ai",
    "sovereign-ai",
    "rag"
  ],
  "author": "Moe Abdelaziz",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Moeabdelaziz007/iqra/issues"
  },
  "homepage": "https://github.com/Moeabdelaziz007/iqra#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/generative-ai": "^0.21.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@supabase/supabase-js": "^2.45.6",
    "@upstash/redis": "^1.34.3",
    "groq-sdk": "^0.8.0",
    "next": "^15.0.0",
    "openai": "^4.73.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "better-sqlite3": "^12.9.0",
    "boxen": "^8.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^8",
    "eslint-config-next": "^15.0.0",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "ora": "^8.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
