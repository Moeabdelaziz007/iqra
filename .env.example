# بسم الله الرحمن الرحيم
# IQRA Environment Variables — Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── LLM Providers ─────────────────────────────────────────────────────────────
GROQ_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Voice (xAI Grok TTS/STT) ──────────────────────────────────────────────────
# xAI TTS: $4.20/M chars — أرخص من ElevenLabs بـ 14x
# 5 أصوات: Ara (هادئ) | Eve | Leo | Rex | Sal
# IQRA v0.369 يستخدم Ara — هادئ، حكيم، عربي
# https://console.x.ai → API Keys
XAI_API_KEY=

# ── Fast Inference (LPU) — مجاني ──────────────────────────────────────────────
# Cerebras: 1M tok/day مجاناً — أسرع من Groq
# https://cloud.cerebras.ai → Get API Key
CEREBRAS_API_KEY=

# ── Memory & Storage ──────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
QDRANT_URL=
QDRANT_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Knowledge Graph & Topology ────────────────────────────────────────────────
# Logseq — مفتوح المصدر، مجاني، AGPL (الأفضل)
# حمّل من: https://logseq.com (مجاني للأبد)
# أنشئ Vault في أي مجلد، ثم أشر إليه هنا
LOGSEQ_VAULT_PATH=

# Obsidian — يعمل محلياً مجاناً (بدون sync)
# Local REST API plugin مطلوب
OBSIDIAN_API_KEY=
OBSIDIAN_VAULT_PATH=

# InfraNodus — مدفوع (بديل مجاني: Gephi Lite)
# https://gephi.org/gephi-lite — مجاني في المتصفح
INFRANODUS_API_KEY=

# ── Quantum Computing — مجاني ─────────────────────────────────────────────────
# IBM Quantum: 10 min/month على 127 qubits
# https://quantum.ibm.com → Get API Token
IBM_QUANTUM_TOKEN=

# ── Design & UI ───────────────────────────────────────────────────────────────
STITCH_API_KEY=
STITCH_BASE_URL=https://stitch.withgoogle.com

# ── Infrastructure ────────────────────────────────────────────────────────────
CLOUDFLARE_AI_GATEWAY_URL=
CLOUDFLARE_AI_GATEWAY_KEY=
GITHUB_TOKEN=
CF_TOKEN=

# ── Local Runtime ─────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_KV_CACHE_TYPE=q8_0

# ── Mode Flags ────────────────────────────────────────────────────────────────
# true = يستخدم Ollama المحلي بدلاً من API
IQRA_LLM_LOCAL=false
# true = يُفعّل التحليل الطوبولوجي
IQRA_TOPOLOGY=true
# true = يُفعّل محاكاة الكم
IQRA_QUANTUM=false
# true = يكتب الاكتشافات في Obsidian
IQRA_OBSIDIAN=false

# ── Models ────────────────────────────────────────────────────────────────────
GOOGLE_GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile
CEREBRAS_MODEL=llama-3.3-70b
